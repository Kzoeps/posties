# Public Vite config only. Do not put secrets, API keys, OAuth tokens, or Linear keys in this file.
# Copy to .env.local for local development.

# Local ATProto OAuth development must run on a loopback origin.
# Start Vite with: pnpm dev --host 127.0.0.1
VITE_PUBLIC_APP_ORIGIN=http://127.0.0.1:5173

# Browser-accessible OAuth metadata URL for the local dev server.
# Production must host public/client-metadata.json at the final HTTPS origin.
VITE_PUBLIC_OAUTH_CLIENT_METADATA_URL=http://127.0.0.1:5173/client-metadata.json

# Test-only flag. Playwright sets this in playwright.config.ts; leave unset for real OAuth/PDS testing.
# VITE_E2E_ATPROTO_MOCK=true
